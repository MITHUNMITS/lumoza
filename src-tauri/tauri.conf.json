{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumoza Studio",
  "version": "0.1.0",
  "identifier": "com.lumoza.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Lumoza Studio",
        "width": 1600,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
